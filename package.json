{
  "name": "cnzr",
  "version": "2.5.0",
  "description": "Cenzero - A minimalist but powerful Node.js web framework",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/esm/core/index.d.ts",
        "default": "./dist/esm/core/index.js"
      },
      "require": {
        "types": "./dist/cjs/core/index.d.ts",
        "default": "./dist/cjs/core/index.js"
      }
    },
    "./middleware": {
      "import": {
        "types": "./dist/esm/middleware/index.d.ts",
        "default": "./dist/esm/middleware/index.js"
      },
      "require": {
        "types": "./dist/cjs/middleware/index.d.ts",
        "default": "./dist/cjs/middleware/index.js"
      }
    },
    "./plugins": {
      "import": {
        "types": "./dist/esm/plugins/index.d.ts",
        "default": "./dist/esm/plugins/index.js"
      },
      "require": {
        "types": "./dist/cjs/plugins/index.d.ts",
        "default": "./dist/cjs/plugins/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "cnzr": "./dist/cjs/cli/index.js"
  },
  "scripts": {
    "build": "npm run clean && npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/cjs/index.js",
    "test": "jest",
    "prepare": "npm run build",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "framework",
    "web",
    "nodejs",
    "typescript",
    "minimalist",
    "express-alternative"
  ],
  "author": "Muhammad Falih Afiq (cenzer0)",
  "license": "MIT",
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "glob": "^11.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "ejs": "^3.1.9"
  },
  "overrides": {
    "minimatch": "^9.0.4",
    "brace-expansion": "^2.0.1",
    "js-yaml": "^4.1.0",
    "diff": "^5.2.0",
    "glob": "^11.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "setupFilesAfterEnv": [
      "<rootDir>/test/setup.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "json"
    ],
    "testMatch": [
      "**/test/**/*.test.ts",
      "**/test/**/*.test.js"
    ],
    "transform": {
      "^.+\\.(t|j)sx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ]
    }
  },
  "files": [
    "dist/**/*",
    "README.md"
  ]
}
